{
  "name": "{{REPO_NAME}} (Flutter)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "postCreateCommand": "make setup",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "usernamehw.errorlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[dart]": {
          "editor.defaultFormatter": "Dart-Code.dart-code",
          "editor.rulers": [80]
        },
        "dart.flutterSdkPath": "/flutter"
      }
    }
  }
}
