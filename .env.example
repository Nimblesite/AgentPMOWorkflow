# Copy this file to .env and fill in real values. .env is gitignored.

# Required: GitHub personal access token (needs repo, read:org scopes)
GITHUB_TOKEN=ghp_your_token_here

# Comma-separated GitHub usernames or org names to scan for community PRs/issues
GITHUB_OWNERS=your_github_username

# Path on the HOST to the directory containing your git repos
# This is mounted into the container as /workspaces
REPOS_PATH=../

# Optional: filter out PRs/issues authored by a specific user (e.g. bots)
# GITHUB_EXCLUDE_AUTHOR=dependabot[bot]

# Optional: exclude repos from a domain (e.g. internal mirror)
# GITHUB_EXCLUDE_REPO_DOMAIN=internal.example.com

# Timezone for log timestamps
TZ=UTC
