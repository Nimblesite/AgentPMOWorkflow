---
layout: layouts/base.njk
title: "Releases — {{REPO_NAME}}"
description: "Every {{REPO_NAME}} release with full release notes, generated at build time from the GitHub Releases for {{REPO_NAME}}."
permalink: /releases/
---

{#
  /releases/ page. Implements [WEB-RELEASES].
  Renders the build-time `release` data (templates/website/release.js).
  Notes are rendered with the `releaseNotes` filter (markdown-it, html:false).
#}

<section class="masthead releases-masthead">
  <div class="copy-block">
    <h1>Releases</h1>
    <p>Every {{REPO_NAME}} release with full notes — generated at build time from the GitHub Releases.</p>
    <p class="release-more">
      <a href="{{ release.releasesUrl }}" rel="noopener">View all releases on GitHub</a>
    </p>
  </div>
</section>

<section class="panel">
  {% if release.available and release.items.length %}
  <div class="release-log">
    {% for item in release.items %}
    <article class="release-entry" id="{{ item.tag }}">
      <div class="release-card-header">
        <h2><a href="{{ item.url }}" rel="noopener">{{ item.title }}</a></h2>
        <span class="release-tag">{{ item.tag }}</span>
      </div>
      <p class="release-meta">
        {% if item.publishedDate %}<time datetime="{{ item.publishedAt }}">{{ item.publishedDate }}</time>{% endif %}
        {% if item.prerelease %}<span class="release-state">Prerelease</span>{% endif %}
      </p>
      {% if item.body %}
      <div class="release-notes">{{ item.body | releaseNotes | safe }}</div>
      {% else %}
      <p class="release-notes-empty"><a href="{{ item.url }}" rel="noopener">Read the notes on GitHub</a></p>
      {% endif %}
    </article>
    {% endfor %}
  </div>
  {% else %}
  <p>Releases will appear here once the first version ships. <a href="{{ release.releasesUrl }}" rel="noopener">View all releases on GitHub</a></p>
  {% endif %}
</section>
