<script defer>
document.addEventListener('DOMContentLoaded', function () {
  const cmds = {
    curl: 'curl -fsSL https://raw.githubusercontent.com/MelbourneDeveloper/project_status/main/setup/setup.sh | bash',
    windows: 'irm https://raw.githubusercontent.com/MelbourneDeveloper/project_status/main/setup/setup.ps1 | iex',
    git:  'git clone https://github.com/MelbourneDeveloper/project_status.git && cd project_status && make setup'
  };

  const display = document.getElementById('install-cmd-display');
  const tabs = document.querySelectorAll('.install-tab');
  const copyBtn = document.getElementById('copy-btn');
  const copyLabel = document.getElementById('copy-label');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-pressed', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-pressed', 'true');
      display.textContent = cmds[tab.dataset.cmd];
    });
  });

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const text = display.textContent;
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copy';
        }, 2000);
      } catch (e) {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyLabel.textContent = 'Copied!';
        setTimeout(() => { copyLabel.textContent = 'Copy'; }, 2000);
      }
    });
  }
});
</script>
